# Local environment variables for ron_GIT

# Rotate multiple Groq keys for local execution
GROQ_API_KEY_1=your-groq-key-1
GROQ_API_KEY_2=your-groq-key-2
GROQ_API_KEY_3=your-groq-key-3

# Groq model reference
GROQ_MODEL=llama-3.1-8b-instant

# Agent rate limiting and context settings
AGENT_LOOP_DELAY=10000
MAX_CONTEXT_FILES=10

# Disable actual Groq requests by default
ENABLE_GROQ=false
